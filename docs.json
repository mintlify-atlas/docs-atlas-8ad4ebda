{
  "$schema": "https://mintlify.com/docs.json",
  "name": "KilomeTracker",
  "theme": "almond",
  "colors": {
    "primary": "#4F46E5",
    "light": "#EEF2FF",
    "dark": "#312E81"
  },
  "favicon": "/favicon.svg",
  "navbar": {
    "primary": {
      "type": "github",
      "href": "https://github.com/javierhrzgt/kilometracker-front"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/javierhrzgt/kilometracker-front"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get Started",
            "pages": ["introduction", "quickstart"]
          },
          {
            "group": "Vehicles",
            "pages": ["vehicles/managing-vehicles", "vehicles/vehicle-stats"]
          },
          {
            "group": "Tracking",
            "pages": ["tracking/routes", "tracking/fuel", "tracking/maintenance"]
          },
          {
            "group": "Expenses",
            "pages": ["expenses/expenses", "expenses/recurring-expenses"]
          },
          {
            "group": "Account",
            "pages": ["account/profile", "account/admin-users"]
          }
        ]
      },
      {
        "tab": "Developer Guide",
        "groups": [
          {
            "group": "Setup",
            "pages": ["dev/setup", "dev/environment"]
          },
          {
            "group": "Architecture",
            "pages": ["dev/architecture", "dev/api-proxy", "dev/authentication"]
          },
          {
            "group": "Reference",
            "pages": ["dev/types", "dev/components"]
          }
        ]
      }
    ]
  }
}
